# ============================================================================
# CT-Watcher ESP32 项目 - Git 忽略规则
# ============================================================================

# ============================================================================
# Python 虚拟环境
# 说明: 虚拟环境文件不应该提交到版本控制中，开发者应该各自创建自己的虚拟环境
# ============================================================================
venv/
.venv/
ENV/

# ============================================================================
# ESP-IDF 编译输出
# 说明: 包含编译生成的目标文件、可执行文件和中间文件
#      这些文件是从源代码生成的，应该在每次构建时重新生成
# ============================================================================
build/                 
sdkconfig              
sdkconfig.old
*.bin                  
*.elf                  
*.map                  

# ============================================================================
# IDE 和编辑器配置
# 说明: IDE 生成的私有配置文件反映个人开发环境设置，不应共享
# ============================================================================
.vscode/               
.idea/                 
*.swp

# ============================================================================
# 操作系统文件
# 说明: macOS 和 Windows 生成的系统文件和缩略图缓存
# ============================================================================
.DS_Store
Thumbs.db